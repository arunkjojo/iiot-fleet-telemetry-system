{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Fleet": ""
  },
  "_comment_Fleet": "Set via env var: ConnectionStrings__Fleet=Host=...;Port=5432;Database=fleet_telemetry;Username=...;Password=...",
  "USE_LIVE_TELEMETRY": false,
  "TelemetryPersistence": {
    "_comment": "Untuned defaults carried over from the original hard-coded values (ADR-001, action item #2). Not yet validated under sustained full 10k-vehicle load.",
    "ChannelCapacity": 50000,
    "FlushIntervalMs": 1000,
    "MaxBatchSize": 2000,
    "MaxRetryAttempts": 2,
    "RetryDelayMs": 250,
    "DeadLetterDirectory": "deadletter"
  }
}
